# Server
PORT=3000
NODE_ENV=development
# Required in production: prevents Host header injection in HTTPS redirects
# PUBLIC_HOST=your-domain.example.com

# PostgreSQL
DATABASE_URL=postgres://vaalikone:vaalikone@localhost:5432/vaalikone

# Admin secret (used as Bearer token for admin endpoints)
ADMIN_SECRET=change-me-to-a-real-secret

# CORS origin (your frontend URL)
CORS_ORIGIN=http://localhost:5173
