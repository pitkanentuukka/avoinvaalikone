# Server
PORT=3000
NODE_ENV=development
# Required in production: prevents Host header injection in HTTPS redirects
# PUBLIC_HOST=your-domain.example.com

# PostgreSQL
DATABASE_URL=postgres://vaalikone:vaalikone@localhost:5432/vaalikone

# Admin secret (used as Bearer token for admin endpoints)
ADMIN_SECRET=change-me-to-a-real-secret

# CORS origin (your frontend URL)
CORS_ORIGIN=http://localhost:5173

# Email notifications for new question set submissions (optional)
# Leave SMTP_HOST unset to disable email entirely
ADMIN_EMAIL=admin@example.com
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_FROM=noreply@vaalikone.fi
# SMTP_USER=
# SMTP_PASS=
